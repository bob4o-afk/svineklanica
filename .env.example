# ============================================================================
#  Root env — this is BOTH the Laravel app env AND the docker-compose env.
#  Copy to .env :  cp .env.example .env   then:  php artisan key:generate
#  (Layout: the Laravel app is the repo root; the web client is in apps/web.)
# ============================================================================
APP_NAME="LiberHack Watchdog"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost

# Public hostname the Caddy proxy serves on (compose reads this for TLS).
#  - local dev: "localhost" (Caddy issues a locally-trusted cert)
#  - public demo/prod: your real domain -> Caddy auto-fetches Let's Encrypt
APP_DOMAIN=localhost

# The SPA origin (used by CORS + Sanctum).
FRONTEND_URL=https://localhost

# ---- Database (PostgreSQL) — host "db" is the compose service ----
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=liberhack
DB_USERNAME=liberhack
DB_PASSWORD=change-me-locally

# ---- Redis (queue + cache) — host "redis" is the compose service ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis      # heavy work runs on the `queue` worker container
SESSION_DRIVER=cookie

# ---- Auth (Sanctum) — comma-separated stateful domains for the SPA ----
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:443
SESSION_DOMAIN=localhost

# ---- CORS (security.md §4) — explicit origins, NEVER "*" with credentials ----
CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:5173

# ---- Mail ----
# LOCAL: Mailpit captures everything (UI at http://localhost:8025).
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="watchdog@localhost"
MAIL_FROM_NAME="${APP_NAME}"
#
# REAL SENDING (Resend/Brevo/SES/...): swap the above for your provider, e.g.
#   MAIL_HOST=smtp.resend.com
#   MAIL_PORT=587
#   MAIL_USERNAME=resend
#   MAIL_PASSWORD=<your API key / SMTP password>
#   MAIL_ENCRYPTION=tls
#   MAIL_FROM_ADDRESS=watchdog@yourdomain.bg
# (see plan.txt section 2A for where to get these)

# ---- Security knobs (security.md) ----
RATE_LIMIT_PER_MINUTE=60
ABUSE_BLACKLIST_TTL_MINUTES=60
# Outbound scrape allow-list (SSRF guard) — only these hosts may be fetched.
SCRAPE_ALLOWED_HOSTS=app.eop.bg,aop.bg,ted.europa.eu,data.egov.bg,portal.registryagency.bg

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---- Honeypot / deception (security.md §10) ----
HONEYPOT_ENABLED=true
# Decoy paths no real client ever calls. A hit => almost certainly a bot/scanner
# => fingerprint + auto-blacklist + observe. Never linked from the UI/sitemap.
HONEYPOT_ROUTES=/api/admin,/api/.env,/api/v1/users/export,/api/internal/db-dump,/wp-login.php,/.git/config
# Serve believable FAKE data from an isolated sandbox (never the real DB) to
# waste the attacker's time and study their behavior.
HONEYPOT_SERVE_FAKE_DATA=true

# ---- Monitoring (docker-compose.monitoring.yml) ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
# App error tracking (SaaS). Leave blank to disable.
SENTRY_LARAVEL_DSN=

# ============================================================================
#  PRODUCTION ONLY — used by docker-compose.prod.yml on the VM. Not needed
#  locally. The CI release pipeline pushes images to GHCR; the VM pulls them.
# ============================================================================
# REGISTRY=ghcr.io
# REGISTRY_OWNER=your-github-username-or-org
# IMAGE_TAG=latest
# (and set APP_DOMAIN to your real domain so Caddy issues a Let's Encrypt cert)
