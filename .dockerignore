# Build context for the backend (API) image = repo root. Keep it lean:
# the frontend and JS deps don't belong in the PHP image.
apps/
packages/
node_modules/
vendor/
.env
.git/
.github/
docker-compose.yml
Caddyfile
caddy_data/
caddy_config/
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
.phpunit.result.cache
# Host-built package manifest / config cache must NOT leak into the image — it has
# host-specific paths/providers and breaks boot ("cache.store does not exist").
# The image regenerates these fresh at runtime (entrypoint.sh).
bootstrap/cache/*.php
