# Normalize line endings: the repo stores LF, and the working tree gets LF too
# (overrides a developer's core.autocrlf=true on Windows). This keeps `pint --test`
# deterministic — CRLF-vs-LF was the only thing diverging local from CI.
* text=auto eol=lf

# Explicit text types (belt-and-suspenders for editors that guess)
*.php   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.env   text eol=lf

# Shell scripts must stay LF (already covered, kept explicit for clarity)
Makefile text eol=lf

# Binary assets — never touch their bytes
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
