# Reverse proxy + automatic HTTPS for BOTH dev and prod.
#  - APP_DOMAIN=localhost  -> Caddy uses a locally-trusted internal cert.
#  - APP_DOMAIN=your.domain -> Caddy auto-fetches a free Let's Encrypt cert
#    (host must be publicly reachable on :80/:443 with DNS pointing here).
#
# Upstreams are resolved DYNAMICALLY via Docker's embedded DNS (127.0.0.11) and
# refreshed every 2s. This is what makes the rolling, zero-downtime deploy real:
# when a new app/web container comes up (and the old one drains), Caddy re-resolves
# the service name and load-balances across whatever is currently healthy — no
# cached-IP 502s. Passive retries (lb_try_duration) cover the brief overlap.
#
# Host/port come from compose: dev defaults to Vite (web:5173); prod sets web:80.

{$APP_DOMAIN:localhost} {
	encode gzip

	# Security headers (security.md §8).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# API + auth + health -> Laravel (FrankenPHP in prod, artisan serve in dev)
	@api path /api/* /sanctum/* /_health
	handle @api {
		reverse_proxy {
			dynamic a {
				name {$API_UPSTREAM_HOST:app}
				port {$API_UPSTREAM_PORT:8000}
				refresh 2s
				resolvers 127.0.0.11
			}
			lb_policy round_robin
			lb_try_duration 10s
			lb_try_interval 250ms

			# Behind Cloudflare the REAL client ip is in CF-Connecting-IP — the
			# X-Forwarded-For chain reaching us otherwise resolves to a Cloudflare
			# edge ip, which breaks the SECURITY_IP_WHITELIST match (an operator's
			# whitelisted ip would never be recognised). Rewrite XFF to the true
			# client ip so Laravel's trustProxies('*') sees it. Only set when the
			# header is present, so direct-to-origin requests keep their real XFF.
			header_up X-Forwarded-For {http.request.header.Cf-Connecting-Ip}
		}
	}

	# everything else -> the React app (Vite dev server, or nginx in prod)
	handle {
		# `route` keeps these two reverse_proxy-family directives in written order
		# (forward_auth gate first, then the app proxy).
		route {
			# WHOLE-SITE BLACKLIST GATE (security.md §3) — PROD-ONLY (PAGE_GATE_ENABLED=true).
			# Before serving the SPA shell to a page navigation (a path with NO file
			# extension, i.e. not matching *.*), ask Laravel's /api/_gate. The blacklist
			# middleware there 403s a banned caller, so a ban blocks the ENTIRE page,
			# not just /api. On 2xx forward_auth falls through to the app proxy below.
			# Asset requests (paths with an extension) and DEV (flag unset -> the
			# expression is false) skip the gate, so the frontend never depends on the
			# API being up to load (devops.md §1.1).
			@nav {
				expression `{env.PAGE_GATE_ENABLED} == "true" && !path("*.*")`
			}
			forward_auth @nav {$API_UPSTREAM_HOST:app}:{$API_UPSTREAM_PORT:8000} {
				uri /api/_gate
				method GET
				# Same real-client-ip rewrite as the @api block, so the blacklist gate
				# matches on the true caller ip behind Cloudflare, not an edge ip.
				header_up X-Forwarded-For {http.request.header.Cf-Connecting-Ip}
				lb_try_duration 5s

				# Banned (gate returned 403) -> raise a 403 error so the shared
				# handle_errors block below renders the styled page instead of
				# Laravel's JSON (whose inline styles the API CSP would strip too).
				# A 2xx falls through to the app proxy as normal.
				@denied status 403
				handle_response @denied {
					error 403
				}
			}

			reverse_proxy {
				dynamic a {
					name {$WEB_UPSTREAM_HOST:web}
					port {$WEB_UPSTREAM_PORT:5173}
					refresh 2s
					resolvers 127.0.0.11
				}
				lb_policy round_robin
				lb_try_duration 10s
				lb_try_interval 250ms
			}
		}
	}

	# Reusable styled error page (security.md §3). Renders deploy/caddy/error.html
	# for ANY error raised in the chain above — the gate's 403, plus proxy-level
	# 502/503 if an upstream is down — switching its copy on the status code. The
	# `status` override keeps the real error code (file_server would otherwise send
	# 200). Mounted at /srv/caddy-errors in the proxy container (compose).
	handle_errors {
		root * /srv/caddy-errors
		rewrite * /error.html
		templates
		file_server {
			status {err.status_code}
		}
	}
}
