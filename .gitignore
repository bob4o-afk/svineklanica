# Env / secrets — ignore every .env variant, keep only the *.example templates
.env*
**/.env*
!.env.example
!.env.prod.example
!**/.env.example

# Laravel (repo root)
/vendor/
/public/build/
/public/hot
/storage/*.key
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*.php
.phpunit.result.cache

# Frontend (apps/web)
/apps/web/node_modules/
/apps/web/dist/
/apps/web/dev-dist/
/apps/web/.vite/
/apps/web/coverage/
node_modules/

# Docker / Caddy
caddy_data/
caddy_config/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

# Scraping layer (apps/scraper, Python)
/apps/scraper/.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Scraper ingest output — heavy/generated. Keep the committed demo samples + .gitkeep.
/storage/ingest/raw/*
!/storage/ingest/raw/.gitkeep
/storage/ingest/normalized/*
!/storage/ingest/normalized/.gitkeep
