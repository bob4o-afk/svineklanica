# ---- Secrets & env ----
.env
.env.*
!.env.example
*.local
secrets/

# ---- Python (/api, /data) ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.uv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---- Node / web (/web) ----
node_modules/
dist/
build/
.vite/
.turbo/
*.tsbuildinfo
.eslintcache
pnpm-debug.log*
npm-debug.log*

# ---- Browser extension build (WXT) ----
.output/
.wxt/
web-ext-artifacts/

# ---- Data artifacts ----
# Commit small/curated datasets deliberately; ignore heavy raw dumps by default.
*.duckdb
*.duckdb.wal
data/raw/
data/cache/
*.zip
# Keep example/curated data explicitly:
!data/curated/**
!**/*.example.csv

# ---- Generated contract types (regenerate from OpenAPI; don't hand-edit) ----
# Tracked on purpose so /web builds without /api running; regenerate via the type-gen script.
# (Uncomment to stop tracking if it causes merge noise)
# shared/types/

# ---- OS / editor ----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
