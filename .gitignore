# Env / secrets — ignore every .env variant, keep only the *.example templates
.env*
**/.env*
!.env.example
!.env.prod.example
!**/.env.example

# Laravel (repo root)
/vendor/
/public/build/
/public/hot
/storage/*.key
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*.php
.phpunit.result.cache

# Frontend (apps/web)
/apps/web/node_modules/
/apps/web/dist/
/apps/web/dev-dist/
/apps/web/.vite/
/apps/web/coverage/
/apps/web/.pnpm-store/
node_modules/

# Docker / Caddy
caddy_data/
caddy_config/
# Caddy's local-dev root CA — generated per machine, trusted into the OS store
# once locally; never a shared artifact (see docker-compose.yml `web` notes).
*.crt

# Local scratch / working notes (not a deliverable)
/todo/

# Secret-bearing scratch files — NEVER commit (private keys, passwords)
temp_env.txt
*_env.txt
*.pem
id_ed25519*
id_rsa*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

# Playwright MCP QA scratch (page/console snapshots, screenshots) — never commit
.playwright-mcp/

# Stray local proxy/debug capture — never commit
proxy_log.txt

# Scraping layer (apps/scraper, Python)
/apps/scraper/.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# AI corruption-detector layer (apps/ai, Python)
/apps/ai/.venv/

# Scraper ingest output — heavy/generated. Keep the committed demo samples + .gitkeep.
/storage/ingest/raw/*
!/storage/ingest/raw/.gitkeep
/storage/ingest/normalized/*
!/storage/ingest/normalized/.gitkeep
# Embedding sidecars — heavy vectors; keep only the committed demo sample.
/storage/ingest/embeddings/*
!/storage/ingest/embeddings/.gitkeep
# AI verdict sidecars — generated; keep only the committed demo samples.
/storage/ingest/verdicts/*
!/storage/ingest/verdicts/.gitkeep
# On-disk fetch cache + downloaded embedding models — never commit.
/storage/ingest/.cache/
/apps/scraper/.fastembed_cache/
**/local_cache/
