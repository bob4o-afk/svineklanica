# apps/ai — AI corruption-detector config. Copy to .env and fill in.
# The real .env is gitignored (root .gitignore: .env*). NEVER commit a real key.

# --- Gemini (via LangChain `langchain-google-genai`) ---
# Get a key from Google AI Studio. Leave empty in the committed example.
GOOGLE_API_KEY=
# Model id. Default targets Gemini 3 Flash. If the API rejects this id, try
# gemini-3.5-flash or gemini-3.1-pro-preview.
GEMINI_MODEL=gemini-3.1-flash-lite
# Gemini 3 reasoning depth: low | medium | high (low = fast/cheap for analytic agents).
GEMINI_THINKING_LEVEL=low
# Sampling temperature for analysis (0 = most deterministic / auditable).
GEMINI_TEMPERATURE=0

# --- Pipeline knobs ---
# Max records to analyze per `analyze` run (empty = no limit).
ANALYZE_LIMIT=
# Optional path to a JSON file overriding signal weights / thresholds.
ANALYZER_WEIGHTS_PATH=

# --- Shared ingest dir (bind-mounted in Docker) ---
# In Docker this is set to /data/ingest. Locally it resolves to <repo>/storage/ingest.
INGEST_OUT_DIR=

# --- Embeddings (reused from the scraper layer for similar/re-tender detection) ---
# Use the same backend/model as the scraper. `hashing` needs no model download.
EMBED_BACKEND=fastembed
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
