# ============================================================================
#  Frontend (Vite) env — copy to frontend/.env. Only VITE_* vars reach the app.
# ============================================================================

# Base URL of the Laravel API. Behind the Caddy proxy the API is same-origin
# under /api, so this can stay relative in local dev.
VITE_API_URL=/api

VITE_APP_NAME="Свинекланица Watchdog"

# MUI X Premium license key (DataGrid Premium, pro charts/pickers).
# Community components work WITHOUT this. Get a (trial) key at https://mui.com/x/.
# Leave blank to use Community / accept the watermark.
VITE_MUI_X_LICENSE_KEY=

# Mock API layer (MSW). Defaults ON in dev, OFF in prod builds. Set to false to hit a real
# backend in dev once the API_SEAM.md endpoints exist.
VITE_ENABLE_MOCKS=

# Sentry DSN for remote error monitoring (Phase 5). Leave blank to disable — monitoring is a
# no-op without it and @sentry/react is code-split out of the build. Get a DSN at https://sentry.io/.
VITE_SENTRY_DSN=
