# apps/scraper config. Copy to .env:  cp .env.example .env
# (.env is gitignored — never commit real values. No secrets/API keys are
#  required: every source here is public open data.)

# Where normalized/raw/samples are written. In Docker this is the shared
# bind-mount with the Laravel app; locally it defaults to <repo>/storage/ingest.
INGEST_OUT_DIR=/data/ingest

# Polite-scraper knobs (see .claude/rules/scraping.md §6)
USER_AGENT="LiberHack-Watchdog/0.1 (+https://github.com/BabyNejii/corruption-fucker)"
REQUEST_TIMEOUT_S=30
RATE_LIMIT_RPS=1

# --- Embeddings (semantic search; uv sync --extra embed) ---------------------
# Vectors are written to storage/ingest/embeddings/<source>.ndjson and joined by
# natural_key in the backend's pgvector. No API key needed — the model is public.
EMBED_BACKEND=fastembed
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_BATCH=64

# --- Per-source config -------------------------------------------------------
# Only the source base_url hosts are fetchable (SSRF allow-list, security.md §4).
# Enable a source with <ID>_ENABLED=true. The *_RESOURCES / *_URLS / *_PAGES /
# *_QUERY values point the source at the concrete data to pull (filled on site).

# TED — Tenders Electronic Daily (EU notices incl. above-threshold BG tenders).
# Structured JSON API; the default query selects Bulgarian buyers. Works as-is.
TED_ENABLED=false
TED_BASE_URL=https://ted.europa.eu
TED_QUERY="buyer-country=BGR SORT BY publication-date DESC"
TED_PAGE_SIZE=100

# data.egov.bg — National Open Data Portal (custom API: POST getResourceData).
# EGOV_RESOURCES = comma-separated resource_uri values of procurement datasets.
EGOV_ENABLED=false
EGOV_BASE_URL=https://data.egov.bg
EGOV_RESOURCES=

# ЦАИС ЕОП contracts — bulk caiseop_contracts*.csv published on data.egov.bg.
# CAISEOP_CSV_URLS = comma-separated full CSV download URLs (data.egov.bg host).
CAISEOP_ENABLED=false
CAISEOP_BASE_URL=https://data.egov.bg
CAISEOP_CSV_URLS=

# АОП / РОП — Register of public procurement (historical, HTML).
# AOP_PAGES = comma-separated listing-page URLs to parse.
AOP_ENABLED=false
AOP_BASE_URL=https://www.aop.bg
AOP_PAGES=

# SEBRA — budget payments (delayed-payments detector). CSV/report exports.
SEBRA_ENABLED=false
SEBRA_BASE_URL=https://minfin.bg
SEBRA_CSV_URLS=

# ЦАИС ЕОП search UI (app.eop.bg) — JS-rendered, needs the `browser` extra:
#   uv sync --extra browser && uv run playwright install chromium
EOP_ENABLED=false
EOP_BASE_URL=https://app.eop.bg
EOP_PAGES=

# ИСУН 2020 EU-funds (2020.eufunds.bg) — WAF-gated, needs the `browser` extra.
ISUN_ENABLED=false
ISUN_BASE_URL=https://2020.eufunds.bg
ISUN_PAGES=

# NCPR (Healthcare drug ceiling prices)
NCPR_ENABLED=false
NCPR_BASE_URL=https://www.ncpr.bg
NCPR_CSV_URLS=

# NHIF (Healthcare tenders)
NHIF_ENABLED=false
NHIF_BASE_URL=https://www.nhif.bg
NHIF_PAGES=

# MZ (Healthcare ministry tenders)
MZ_ENABLED=false
MZ_BASE_URL=https://www.mh.government.bg
MZ_PAGES=

# MZ Jobs (Hospital director competitions)
MZ_JOBS_ENABLED=false
MZ_JOBS_BASE_URL=https://www.mh.government.bg
MZ_JOBS_PAGES=

# MZ Assets (Hospital asset disposal)
MZ_ASSETS_ENABLED=false
MZ_ASSETS_BASE_URL=https://www.mh.government.bg
MZ_ASSETS_PAGES=

# VSS (Judiciary tenders)
VSS_ENABLED=false
VSS_BASE_URL=https://profile-op.vss.justice.bg
VSS_PAGES=

# PRB (Prosecutor's Office tenders)
PRB_ENABLED=false
PRB_BASE_URL=https://prb.bg
PRB_PAGES=

# VSS Jobs (Magistrate competitions)
VSS_JOBS_ENABLED=false
VSS_JOBS_BASE_URL=https://vss.justice.bg
VSS_JOBS_PAGES=

# IVSS Declarations (Magistrate property declarations)
IVSS_DECLARATIONS_ENABLED=false
IVSS_DECLARATIONS_BASE_URL=https://www.inspectoratvss.bg
IVSS_DECLARATIONS_PAGES=

# MJS Assets (Judiciary property sales)
MJS_ASSETS_ENABLED=false
MJS_ASSETS_BASE_URL=https://www.mjs.bg
MJS_ASSETS_PAGES=

# MVR (Police tenders)
MVR_ENABLED=false
MVR_BASE_URL=https://mvr.bg
MVR_PAGES=

# MVR Donations (Police donations)
MVR_DONATIONS_ENABLED=false
MVR_DONATIONS_BASE_URL=https://mvr.bg
MVR_DONATIONS_PAGES=

# MVR Jobs (Police hiring)
MVR_JOBS_ENABLED=false
MVR_JOBS_BASE_URL=https://mvr.bg
MVR_JOBS_PAGES=

# MVR Assets (Police asset disposal)
MVR_ASSETS_ENABLED=false
MVR_ASSETS_BASE_URL=https://mvr.bg
MVR_ASSETS_PAGES=
