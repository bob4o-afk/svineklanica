# apps/scraper config. Copy to .env:  cp .env.example .env
# (.env is gitignored — never commit real values. No secrets/API keys are
#  required: every source here is public open data.)

# Where normalized/raw/samples are written. In Docker this is the shared
# bind-mount with the Laravel app; locally it defaults to <repo>/storage/ingest.
INGEST_OUT_DIR=/data/ingest

# Polite-scraper knobs (see .claude/rules/scraping.md §6)
USER_AGENT="LiberHack-Watchdog/0.1 (+https://github.com/BabyNejii/corruption-fucker)"
REQUEST_TIMEOUT_S=30
RATE_LIMIT_RPS=1

# --- Per-source config -------------------------------------------------------
# Only the source base_url hosts are fetchable (SSRF allow-list, security.md §4).
# Enable a source with <ID>_ENABLED=true. The *_RESOURCES / *_URLS / *_PAGES /
# *_QUERY values point the source at the concrete data to pull (filled on site).

# TED — Tenders Electronic Daily (EU notices incl. above-threshold BG tenders).
# Structured JSON API; the default query selects Bulgarian buyers. Works as-is.
TED_ENABLED=false
TED_BASE_URL=https://ted.europa.eu
TED_QUERY="buyer-country=BGR SORT BY publication-date DESC"
TED_PAGE_SIZE=100

# data.egov.bg — National Open Data Portal (custom API: POST getResourceData).
# EGOV_RESOURCES = comma-separated resource_uri values of procurement datasets.
EGOV_ENABLED=false
EGOV_BASE_URL=https://data.egov.bg
EGOV_RESOURCES=

# ЦАИС ЕОП contracts — bulk caiseop_contracts*.csv published on data.egov.bg.
# CAISEOP_CSV_URLS = comma-separated full CSV download URLs (data.egov.bg host).
CAISEOP_ENABLED=false
CAISEOP_BASE_URL=https://data.egov.bg
CAISEOP_CSV_URLS=

# АОП / РОП — Register of public procurement (historical, HTML).
# AOP_PAGES = comma-separated listing-page URLs to parse.
AOP_ENABLED=false
AOP_BASE_URL=https://www.aop.bg
AOP_PAGES=

# SEBRA — budget payments (delayed-payments detector). CSV/report exports.
SEBRA_ENABLED=false
SEBRA_BASE_URL=https://minfin.bg
SEBRA_CSV_URLS=

# ЦАИС ЕОП search UI (app.eop.bg) — JS-rendered, needs the `browser` extra:
#   uv sync --extra browser && uv run playwright install chromium
EOP_ENABLED=false
EOP_BASE_URL=https://app.eop.bg
EOP_PAGES=

# ИСУН 2020 EU-funds (2020.eufunds.bg) — WAF-gated, needs the `browser` extra.
ISUN_ENABLED=false
ISUN_BASE_URL=https://2020.eufunds.bg
ISUN_PAGES=
