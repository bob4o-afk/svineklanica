# ============================================================================
#  PRODUCTION env — for the VM, consumed by docker-compose.prod.yml.
#  On the server:  cp .env.prod.example .env   then fill in every <REPLACE_ME>.
#  NEVER commit the filled-in .env (it's git-ignored). Paste real secrets here.
# ============================================================================
APP_NAME="LiberHack Watchdog"
APP_ENV=production
APP_DEBUG=false

# Laravel app secret. Generate once and paste it here:
#   docker run --rm ghcr.io/<owner>/liberhack-api:<tag> php artisan key:generate --show
APP_KEY=<REPLACE_ME base64:...>

# Your real domain — Caddy uses it to fetch a free Let's Encrypt cert.
APP_DOMAIN=your-domain.bg
APP_URL=https://your-domain.bg
FRONTEND_URL=https://your-domain.bg

# ---- Images to run (CI pushed these to GHCR on the release tag) ----
REGISTRY=ghcr.io
REGISTRY_OWNER=<your-github-username-or-org>
IMAGE_TAG=<REPLACE_ME e.g. v1.0.0>

# ---- Database (PostgreSQL) ----
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=liberhack
DB_USERNAME=liberhack
DB_PASSWORD=<REPLACE_ME strong-random-password>

# ---- Redis (queue + cache) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie

# ---- Auth (Sanctum) ----
SANCTUM_STATEFUL_DOMAINS=your-domain.bg
SESSION_DOMAIN=your-domain.bg

# ---- CORS — explicit origin, never "*" with credentials ----
CORS_ALLOWED_ORIGINS=https://your-domain.bg

# ---- Mail (real transactional provider — Resend/Brevo/SES). Paste secrets. ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=<REPLACE_ME API key / SMTP password>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=watchdog@your-domain.bg
MAIL_FROM_NAME="${APP_NAME}"

# ---- Security (security.md) ----
RATE_LIMIT_PER_MINUTE=60
ABUSE_BLACKLIST_TTL_MINUTES=60
SCRAPE_ALLOWED_HOSTS=app.eop.bg,aop.bg,ted.europa.eu,data.egov.bg,portal.registryagency.bg

# ---- Honeypot / deception (security.md §10) ----
HONEYPOT_ENABLED=true
HONEYPOT_ROUTES=/api/admin,/api/.env,/api/v1/users/export,/api/internal/db-dump,/wp-login.php,/.git/config
HONEYPOT_SERVE_FAKE_DATA=true

# ---- Monitoring (docker-compose.monitoring.yml) ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<REPLACE_ME>
SENTRY_LARAVEL_DSN=

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ============================================================================
#  NOTE: the SSH DEPLOY KEY does NOT go in this file. The private key
#  (~/.ssh/liberhack_deploy) goes into the GitHub repo secret DEPLOY_SSH_KEY,
#  and its PUBLIC half goes on the VM (bulinfo.net panel / ~/.ssh/authorized_keys).
#  Env files hold app secrets; SSH auth is handled by the server + GitHub secrets.
# ============================================================================
